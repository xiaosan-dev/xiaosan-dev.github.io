{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"strictNullChecks": true,
		"allowJs": true,
		"types": ["astro/client"],
		"baseUrl": ".",
		"lib": ["es2022", "dom", "dom.iterable"],
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "**/node_modules/*", ".vscode", "dist"]
}
